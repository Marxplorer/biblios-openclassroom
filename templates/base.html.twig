<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Biblios main page{% endblock %}</title>
        <link rel="icon" href="https://pngimg.com/uploads/letter_b/letter_b_PNG49.png">
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}

        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
        {% endif %}
        <style>
            body {background-color: rgb(88, 136, 224);}
            .welcomecolor {background-color: rgb(88, 136, 224);}
            .aboutcolor {background-color: rgb(211, 214, 221);}
            .navigation {background-color: rgb(0, 0, 0); color: white;}
            ul {list-style-type: none;margin: 0;padding: 0;overflow: hidden;background-color: #333333;}
            .logo li {float: left;}
            .options li {float: right;}
            .options li a {display: block;color: white;text-align: center;padding: 14px 16px;text-decoration: none;}
            .logo li a {display: block;color: white;text-align: center;padding: 14px 16px;text-decoration: none; font-weight: bold;}
        
        </style>
    </head>
    <body>
        <div class="navigation">
            <ul>
                <div class="logo"><li><a href="/main">Biblios</a></li></div>
                <div class="options"><li><a href="/book">Catalogue</a></li></div>
                <div class="options"><li><a href="/admin/menu">Admin</a></li></div>
            </ul>
        </div>
        <div class="welcomecolor">
            {% block body %}{% endblock %}
        </div>
        <div class="aboutcolor">
            {% block about %}{% endblock %}
        </div>
    </body>
</html>
