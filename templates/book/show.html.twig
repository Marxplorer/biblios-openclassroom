{% extends 'base.html.twig' %}
{% block title %}
    {{ book ? book.title : 'Livre introuvable' }}
{% endblock %}
{% block body %}

<div class="container mt-4">

    {% if book %}
        {% if book.coverImage %}
            <img
                src="{{ asset('uploads/covers/' ~ book.coverImage) }}"
                class="img-fluid mb-3"
                alt="{{ book.title }}"
            >
        {% endif %}
        <h1 class="mb-4">{{ book.title }}</h1>
        <div class="card shadow-sm">
            <div class="card-body">
                <p><strong>ISBN :</strong> {{ book.isbn }}</p>
                <p><strong>Éditeur :</strong>
                    {{ book.editor ? book.editor.name : 'Non défini' }}
                </p>
                <p><strong>Auteur(s) :</strong>
                    {% for author in book.authors %}
                        {{ author.name }}{% if not loop.last %}, {% endif %}
                    {% else %}
                        Aucun auteur
                    {% endfor %}
                </p>
                <p><strong>Nombre de pages :</strong> {{ book.pageNumber }}</p>
                <p><strong>Date de sortie :</strong>
                    {{ book.editedAt ? book.editedAt|date('d/m/Y') : '-' }}
                </p>
                <p><strong>Synopsis :</strong></p>
                <p>{{ book.plot }}</p>
            </div>
        </div>
        <a href="{{ path('app_book_index') }}" class="btn btn-primary mt-3">
            ← Retour à la liste
        </a>

    {% else %}

        <div class="alert alert-danger">
            Livre introuvable
        </div>
        <a href="{{ path('app_book_index') }}" class="btn btn-secondary mt-3">
            Retour
        </a>

    {% endif %}
</div>

{% endblock %}